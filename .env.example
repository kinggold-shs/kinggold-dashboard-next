# Copy to .env.local for local dev, or set in Vercel → Project → Environment Variables

# Django / FN6 backend (no trailing slash). Used by axios + media URLs + live price refresh.
NEXT_PUBLIC_API_BASE_URL=https://kinggoldretail.e-jewelry-softwarehouse.com

# Shopify Admin API (server-side only; required for /api/shopify/* route handlers)
# Custom app scopes for GWEB → Shopify sync (publish, variant PUT, code chains, live price refresh):
#   write_products, read_locations, write_inventory — required for binary availability (0/1) on code chains
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_CLIENT_ID=
# Shared secret: OAuth client_credentials + App Proxy HMAC verification (must match the app that owns the proxy)
SHOPIFY_CLIENT_SECRET=

# Optional storefront host for product links in by-sku responses (not used by App Proxy)
SHOPIFY_STOREFRONT_DOMAIN=your-store.myshopify.com

# Live price/weight refresh: min ms between Shopify variant PUTs per SKU (default 5000)
SHOPIFY_REFRESH_PRICE_THROTTLE_MS=5000


# GWEB weight is written to variant metafield custom.gweb_weight (single_line_text_field, e.g. "4.91g").
# Create the definition in Shopify Admin → Settings → Custom data → Variants if required by your shop.

# --- Shopify Partners: App Proxy (KingGold Dashboard custom app) ---
# Subpath prefix: apps/kg
# Subpath:       refresh-price
# Proxy URL:     https://<vercel-app>/api/shopify/proxy/refresh-price
# Storefront:    GET /apps/kg/refresh-price?sku=<mco>  (Shopify adds shop, timestamp, signature, …)
# Docs: https://shopify.dev/docs/apps/build/online-store/app-proxies

# --- Code chains + history: orders/paid webhook ---
# After deploying the dashboard, register in Shopify Admin → Settings → Notifications → Webhooks
# (or via Admin API):
#   Topic: orders/paid
#   URL:   https://<vercel-app>/api/shopify/webhooks/orders-paid
#   Format: JSON
# If Shopify shows a dedicated webhook signing secret, store it here.
SHOPIFY_WEBHOOK_SECRET=
# Falls back to SHOPIFY_CLIENT_SECRET if SHOPIFY_WEBHOOK_SECRET is not set. On payment,
# the active FN6 code in custom.code_chains is marked sold, the next code in that chain
# is synced to Shopify, and a purchase-history snapshot is written back onto the paid order
# as Shopify order metafields.
